# Copy this file to .env and fill in real values.
# Vite only exposes variables prefixed with VITE_ to client-side code.

# TODO: Backend API base URL once the backend is deployed (e.g. via Cloudflare Workers)
VITE_API_BASE_URL=https://api.example.com

# TODO: Razorpay public key (server-side secret key must NEVER go in a frontend env var)
VITE_RAZORPAY_KEY_ID=

# TODO: NGO WhatsApp number in international format, no plus sign (e.g. 91XXXXXXXXXX)
VITE_WHATSAPP_NUMBER=918459073474

# TODO: Google Maps / Places API key, if an interactive map is added to the Contact page
VITE_GOOGLE_MAPS_API_KEY=
